<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 控制台输出配置 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%d{HH:mm:ss}] [%thread/%level] (%logger{0}) %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出配置（可选，用于调试） -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/plot.log</file>
        <encoder>
            <pattern>[%d{yyyy-MM-dd HH:mm:ss}] [%thread/%level] (%logger) %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Plot 模块的日志级别控制 -->
    <logger name="Plot" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    
    <!-- 详细的子模块日志级别控制 -->
    <!-- 方块分类管理器 - 生产环境建议使用 WARN -->
    <logger name="Plot/BlockCategoryManager" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    
    <!-- 方块图标渲染器 - 生产环境建议使用 INFO -->
    <logger name="Plot/BlockIconRenderer" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    
    <!-- 初始化器 - 保持 INFO 级别以监控启动过程 -->
    <logger name="Plot/PlotInitializer" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    
    <!-- 画布核心 - 生产环境建议使用 WARN -->
    <logger name="Plot/CanvasCore" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    
    <!-- 绘图工具 - 生产环境建议使用 WARN -->
    <logger name="Plot/DrawingTool" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    
    <!-- 选择管理 - 生产环境建议使用 WARN -->
    <logger name="Plot/Selection" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- 开发模式：启用详细调试日志 -->
    <!-- 取消注释以下配置以启用调试模式 -->
    <!--
    <logger name="Plot/BlockCategoryManager" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    
    <logger name="Plot/BlockIconRenderer" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    -->

    <!-- 填充工具相关类的详细调试日志 -->
    <logger name="com.plot.ui.tools.impl.modify.FillTool" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    
    <logger name="com.plot.ui.tools.impl.modify.strategy.FillWithSelectionStrategy" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    
    <logger name="com.plot.ui.tools.impl.modify.helper.FillHandler" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    
    <logger name="com.plot.ui.tools.impl.modify.helper.BoundaryDetectionHelper" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    
    <logger name="com.plot.ui.utils.GeometryCalculationUtils" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    
    <!-- 根日志级别 -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
    </root>
    
    <!-- 系统属性控制的动态日志级别 -->
    <!-- 
    使用方法：
    1. 在启动时设置系统属性: -Dplot.debug=true
    2. 或在游戏中设置: System.setProperty("plot.debug", "true")
    -->
    <if condition='property("plot.debug").equals("true")'>
        <then>
            <!-- 调试模式：所有 Plot 日志设为 DEBUG 级别 -->
            <logger name="Plot" level="DEBUG" additivity="false">
                <appender-ref ref="CONSOLE"/>
                <appender-ref ref="FILE"/>
            </logger>
        </then>
    </if>
    
    <if condition='property("plot.trace").equals("true")'>
        <then>
            <!-- 追踪模式：所有 Plot 日志设为 TRACE 级别 -->
            <logger name="Plot" level="TRACE" additivity="false">
                <appender-ref ref="CONSOLE"/>
                <appender-ref ref="FILE"/>
            </logger>
        </then>
    </if>
</configuration> 